# WinOS — environment variable reference
# Copy this file to .env and fill in values for local development.
# Never commit .env — it is gitignored.
# Production values are configured in the AWS Amplify console, not here.

# ── Database ──────────────────────────────────────────────────────────────────
# First-time local setup:  npm run db:setup   (starts DB, creates databases, pushes schema)
# After a machine reboot:  npm run db:restart  (starts DB only — databases persist)
#
# NOTE: The local Prisma dev server runs WASM PostgreSQL which leaks prepared
# statements across connections.  Use `npm run db:schema` (not `prisma db push`
# directly) — it calls scripts/db-push.mjs which clears stale statements first.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/winos?sslmode=disable
# LOCAL DEV ONLY — only needed if running `prisma migrate dev` (we don't).
# Not required in the Amplify console; production uses `prisma migrate deploy`.
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/winos_shadow?sslmode=disable

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate a value with: openssl rand -base64 32
AUTH_SECRET=
# Base URL of this app — used by Auth.js to construct callback URLs
# Local dev: http://localhost:3000
# Production: https://your-domain.amplifyapp.com (or custom domain)
AUTH_URL=
# Required in production: tells Auth.js to trust X-Forwarded-Host from the
# reverse proxy (AWS Amplify load balancer).  Without this, sign-in redirects
# fail with "UntrustedHost".  Set to "true" in the Amplify console.
AUTH_TRUST_HOST=

# ── SMTP / Zoho Mail ──────────────────────────────────────────────────────────
# Production: configure these in the AWS Amplify console.
# India region:   SMTP_HOST=smtp.zoho.in   SMTP_PORT=587
# Global region:  SMTP_HOST=smtp.zoho.com  SMTP_PORT=587
# Use port 465 for SSL instead of STARTTLS.

SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_USER=ishita.vishwakarma@eagleeyedigital.io
SMTP_PASS=8MHqsf1YdJ0z
SMTP_FROM="WinOS <ishita.vishwakarma@eagleeyedigital.io>"



